{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "probe-rs-debug",
      "request": "launch",
      "name": "Debug Blue Pill",
      "cwd": "${workspaceFolder}",
      "chip": "STM32F103C8",
      "flashingConfig": {
        "flashingEnabled": true,
        "resetAfterFlashing": true,
        "haltAfterReset": true
      },
      "coreConfigs": [
        {
          "coreIndex": 0,
          "programBinary": "target/thumbv7m-none-eabi/debug/bluepill_blink"
        }
      ]
    }
  ]
}